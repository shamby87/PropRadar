# Comma-separated API keys from the-odds-api.com
API_KEYS=key1,key2

# Copy Cookie header from a logged-in request to api.prizepicks.com (DevTools → Network)
PRIZEPICKS_COOKIE=

# Authorization header from Sleeper API requests
SLEEPER_AUTH=

# Sleeper league ID (optional; used when sharing parlays)
SLEEPER_LEAGUE_ID=

# Discord webhooks and IDs
PARLAY_WEBHOOK=
ADMIN_WEBHOOK=
SLEEPER_PLAYS_WEBHOOK=
SLEEPER_ROLE_ID=
ADMIN_ID=

# Set to 1, true, yes, or on to log Sleeper parlays without submitting (optional)
SLEEPER_DRY_RUN=
